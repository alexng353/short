      "SignupBody": {
        "type": "object",
        "required": [
          "invite_code",
          "name",
          "username",
          "password"
        ],
        "properties": {
          "invite_code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        }
